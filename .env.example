# API (apps/api)
# Port for the Hono API server (default: 3834)
PORT=3834

# PostgreSQL connection string for Drizzle ORM
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# Clerk (get keys from https://dashboard.clerk.com → API Keys)
# Web app needs publishable key; API needs secret key for JWT verification
VITE_CLERK_PUBLISHABLE_KEY=pk_test_
CLERK_SECRET_KEY=sk_test_

# Web (apps/web)
# API base URL for the frontend. Leave empty for same-origin (Vite proxy in dev, or same host in prod).
# Example for production: https://api.example.com
VITE_API_URL=
